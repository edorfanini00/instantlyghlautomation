# Instantly.ai API Key (from Settings → Integrations → API)
INSTANTLY_API_KEY=your-instantly-api-key-here

# GoHighLevel Private Integration Token
GHL_API_KEY=pit-XXXXXXXXXXXX

# GoHighLevel Location (sub-account) ID
GHL_LOCATION_ID=XXXXXXXXXXXX

# Vercel Cron Secret (set in Vercel dashboard → Settings → Environment Variables)
CRON_SECRET=your-random-secret-here

# Optional: Port for local development
PORT=3000
